# ============================================
# 谛观 GreenwashGuard - Git忽略文件
# ============================================

# ---- Python 编译缓存 ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- 虚拟环境 ----
venv/
env/
ENV/
.venv/
.env/

# ---- 环境变量（不提交密钥） ----
.env
.env.local
.env.*.local
backend/.env
!backend/.env.example
!**/.env.example

# ---- IDE / 编辑器 ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- 系统文件 ----
.DS_Store
Thumbs.db
desktop.ini
*.lnk

# ---- 日志文件 ----
*.log
logs/
*.log.*
launcher.log

# ---- 运行时文件 ----
.server.pid
.start_server_temp.py

# ---- 前端依赖和构建产物 ----
# 注意：frontend/dist/ 已预构建，需要保留！
frontend/node_modules/
frontend/.vite/

# ---- 数据库文件 ----
*.db
*.sqlite
data/db/
data/pgdata/
backend/data/db/

# ---- 批量分析进度 ----
*_progress*.txt

# ---- 临时文件 ----
tmp/
temp/
*.tmp
*.bak
*.cache

# ---- 测试覆盖率 ----
.coverage
htmlcov/
.pytest_cache/
.tox/
.hypothesis/

# ---- 大量数据文件（CMDA年报文本，体积大，不提交） ----
data/CMDA_管理层讨论与分析_ALL/
data/**/*.txt
data/readme*.txt
!backend/data/*.json
!backend/**/readme.txt
!frontend/**/readme.txt
!readme.txt
!README.md
!technical_design.md

# ---- PDF/DOC等文档 ----
*.pdf
*.docx
*.doc
